# Thunderbolt Agent — Environment Variables

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GHL Webhook (for hot lead notifications + contact creation)
GHL_WEBHOOK_URL=https://your-ghl-webhook-url-here

# Email (for sending proposals — use Gmail App Password or SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
FROM_EMAIL=ian@thunderboltsalessystems.com
FROM_NAME=Ian | Thunderbolt Sales Systems

# Proposal PDF URL (hosted on your site or GHL)
PROPOSAL_PDF_URL=https://thunderboltsalessystems.com/proposal.pdf

# Payment link (GHL invoice or Stripe)
PAYMENT_LINK=https://app.gohighlevel.com/payment/your-link-here

# Booking calendar
BOOKING_URL=https://api.leadconnectorhq.com/widget/booking/6WoevlYOQj2VrBKsOVrI

# Agent config
PORT=3001
AGENT_NAME=Ian
COMPANY_NAME=Thunderbolt Sales Systems
HOT_LEAD_SCORE=7
